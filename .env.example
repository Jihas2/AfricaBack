# ─── Copy this file to .env and fill in real values before running in production ─

# ─── Database ────────────────────────────────────────────────────────────────
# Never use root/root in production. Create a dedicated MySQL user with least privilege.
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/residence_db?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=residence_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
APP_JWT_SECRET=CHANGE_ME_at_least_32_random_characters

# ─── Application URLs ─────────────────────────────────────────────────────────
# Must be HTTPS in production. Used for redirect URLs and webhook registration.
APP_FRONTEND_URL=https://residence.example.com
APP_BACKEND_URL=https://api.residence.example.com

# ─── CORS ────────────────────────────────────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=https://residence.example.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Use sk_live_... for production, sk_test_... for development.
STRIPE_SECRET_KEY=sk_live_CHANGE_ME

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Register endpoint: POST https://api.residence.example.com/api/webhooks/stripe
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── PayPal ──────────────────────────────────────────────────────────────────
# Dashboard: https://developer.paypal.com/dashboard/applications/live
# Set PAYPAL_MODE=live for production, sandbox for development.
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_MODE=live

# ─── CinetPay ────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.cinetpay.com
# IPN (notify_url) must be publicly reachable by CinetPay servers.
CINETPAY_API_KEY=CHANGE_ME
CINETPAY_SITE_ID=CHANGE_ME

# ─── Bank Transfer Details ───────────────────────────────────────────────────
BANK_ACCOUNT_NAME=Résidence Romeo Golf SARL
BANK_ACCOUNT_NUMBER=CD 00000 00000 00000000000 00
BANK_NAME=Rawbank
BANK_SWIFT=RAWBCDKI
